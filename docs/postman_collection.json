{
  "info": {
    "name": "backend-tbd",
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "description": "Postman collection scaffold for backend-tbd",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Employee Assessment",
      "item": [
        {
          "name": "Start (invite)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-invite-token",
                "value": "{{INVITE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-assessment/start",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-assessment",
                "start"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": ""
    },
    {
      "key": "INVITE_TOKEN",
      "value": ""
    }
  ]
}
